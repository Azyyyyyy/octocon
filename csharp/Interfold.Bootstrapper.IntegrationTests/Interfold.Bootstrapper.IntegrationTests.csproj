<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>false</IsPackable>
    <TestingPlatformDotnetTestSupport>true</TestingPlatformDotnetTestSupport>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Interfold.Bootstrapper.IntegrationTests</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Same TUnit pin as csharp/Interfold.IntegrationTests so the two test projects stay in sync. -->
    <PackageReference Include="TUnit" Version="1.50.0" />
    <!-- Testcontainers drives the per-distro DinD lifecycle. 4.x is reflection-light and AOT-friendly. -->
    <PackageReference Include="Testcontainers" Version="4.12.0" />
  </ItemGroup>

  <ItemGroup>
    <!--
      We need the bootstrapper csproj on disk (to invoke `dotnet publish` at test-fixture time),
      but we don't need to compile-link the assembly into the test binary. The fixture shells out
      to `dotnet publish` directly so it exercises exactly the same code path a release build
      would, and so the test binary stays free of the Aspire reflection footprint.
    -->
    <ProjectReference Include="..\Interfold.Bootstrapper\Interfold.Bootstrapper.csproj"
                      ReferenceOutputAssembly="false"
                      Private="false"
                      ExcludeAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <!-- Per-distro DinD Dockerfiles shipped to bin/ so tests can hand them to ImageFromDockerfileBuilder. -->
    <Content Include="fixtures\Dockerfile.*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="fixtures\dockerd-entrypoint.sh">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <!-- All bootstrap test config variants. Tests that need a custom port, bad image, or other
         knob ship a sibling .json under fixtures/. The glob keeps the csproj stable as new
         scenarios are added. -->
    <Content Include="fixtures\interfold.bootstrap.test*.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
