{
  "version": 1,
  "description": "Settings lifecycle: update username, update description — with idempotency replay.",
  "steps": [
    {
      "name": "update username",
      "method": "PATCH",
      "path": "/api/systems/me/username",
      "principalId": "replay-sys-settings",
      "idempotencyKey": "replay-settings-username-001",
      "body": { "username": "replayuser" },
      "expectedStatus": 200,
      "expectedReplay": false
    },
    {
      "name": "update username (replay)",
      "method": "PATCH",
      "path": "/api/systems/me/username",
      "principalId": "replay-sys-settings",
      "idempotencyKey": "replay-settings-username-001",
      "body": { "username": "replayuser" },
      "expectedStatus": 200,
      "expectedReplay": true
    },
    {
      "name": "update description",
      "method": "PATCH",
      "path": "/api/systems/me/description",
      "principalId": "replay-sys-settings",
      "idempotencyKey": "replay-settings-desc-001",
      "body": { "description": "replay description" },
      "expectedStatus": 200,
      "expectedReplay": false
    },
    {
      "name": "update description (replay)",
      "method": "PATCH",
      "path": "/api/systems/me/description",
      "principalId": "replay-sys-settings",
      "idempotencyKey": "replay-settings-desc-001",
      "body": { "description": "replay description" },
      "expectedStatus": 200,
      "expectedReplay": true
    }
  ]
}
