{
  // Copy this file to launchSettings.json and customise. See docs/configuration.md for the
  // full reference. Anything marked <set-via-user-secrets> should be moved out of source
  // control via `dotnet user-secrets set "<key>" "<value>" --project csharp/Interfold.Api`.
  "profiles": {
    "Octocon.Api": {
      "commandName": "Project",
      "launchBrowser": true,
      "environmentVariables": {
        // --- ASP.NET Core host ---
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://api.octocon.app;https://api.octocon.app",

        // --- Persistence ---
        // Mode: 'inmemory' for solo-API dev; 'scylla-postgres' against a real cluster
        // (typically via `aspire run` instead of launching the API directly).
        "OCTOCON_PERSISTENCE": "inmemory",
        // Only read in scylla-postgres mode. Defaults to localhost if unset.
        "OCTOCON_POSTGRES_CONNECTION": "<set-via-user-secrets>",
        // Per-node region identity. Drives the Scylla session keyspace AND new-account routing.
        // Values: nam | eur | ocn | eas | sam | sas | gdpr. No store fallback.
        "OCTOCON_SCYLLA_KEYSPACE": "nam",
        // Dev/test override for Scylla contact points + port. In production these are read
        // from internal.secrets (scylla:contact_points / scylla:port).
        "OCTOCON_SCYLLA_CONTACT_POINTS": "localhost",
        "OCTOCON_SCYLLA_PORT": "9042",
        // 'true' keeps ScyllaMigrationService creating only the keyspace named above —
        // matches the dev/single-node profile.
        "OCTOCON_SINGLE_SCYLLA_INSTANCE": "true",
        // Transient-failure retry strategy for DB operations. Defaults shown.
        "OCTOCON_DB_RETRY_ATTEMPTS": "3",
        "OCTOCON_DB_RETRY_INITIAL_DELAY_MS": "100",
        "OCTOCON_DB_RETRY_MAX_DELAY_MS": "1500",
        // Caps the fan-out for friendship profile/fronting hydration. Default 8.
        "OCTOCON_HYDRATION_MAX_CONCURRENCY": "8",

        // --- Authentication ---
        // Issuer claim emitted on outbound tokens. (The encryption pepper, JWT signing keys,
        // and deep-link HMAC secret are all sourced from internal.secrets at startup — see
        // SecretsBootstrapService.)
        "OCTOCON_JWT_AUTHORITY": "octocon-local",
        // Base URL OAuth callbacks return to (must match the redirect URI registered with
        // each provider).
        "OCTOCON_AUTH_CALLBACK_BASE_URL": "https://api.octocon.app",

        // --- OAuth providers ---
        // The provider authorize URL, the ASP.NET Core challenge scheme name, and the static
        // challenge query parameters (scopes / response_type / response_mode) are all baked
        // into the API as constants — see OAuthChallengeServiceCollectionExtensions. The
        // client_id is injected from these env vars at scheme-registration time, so leaving
        // a *_OAUTH_CLIENT_ID empty disables the provider entirely (the scheme won't
        // register and the controller falls through to 403). Client secrets are sensitive:
        // in self-host they're stored in internal.secrets via SecretsBootstrapService; for
        // solo-API dev set them via user-secrets so they aren't committed.
        "OCTOCON_GOOGLE_OAUTH_CLIENT_ID": "<your-google-client-id>",
        "OCTOCON_GOOGLE_OAUTH_CLIENT_SECRET": "<set-via-user-secrets>",

        "OCTOCON_DISCORD_OAUTH_CLIENT_ID": "<your-discord-client-id>",
        "OCTOCON_DISCORD_OAUTH_CLIENT_SECRET": "<set-via-user-secrets>",

        // Apple's client_secret is a short-lived JWT minted from the team private key —
        // pre-mint outside the bootstrapper and paste it here (or via user-secrets) for
        // solo dev. In self-host it lives in internal.secrets:oauth:apple:client_secret.
        "OCTOCON_APPLE_OAUTH_CLIENT_ID": "<your-apple-client-id>",
        "OCTOCON_APPLE_OAUTH_CLIENT_SECRET": "<set-via-user-secrets>",

        // --- CORS ---
        // Comma-separated allow-list. Empty / unset falls back to "allow any origin", which
        // is fine for solo-API dev but should always be set explicitly in production.
        // (Redirect destinations after OAuth login are now supplied by the client via the
        // redirect_uri query param on GET /auth/{provider}; there is no server-side
        // fallback for the post-login redirect base any more.)
        "OCTOCON_CORS_ALLOWED_ORIGINS": "http://localhost:8080",

        // --- Storage ---
        // Local filesystem root + public CDN base for uploaded avatars. Empty disables uploads.
        "OCTOCON_AVATAR_STORAGE_ROOT": "",
        "OCTOCON_AVATAR_PUBLIC_BASE": "",

        // --- Observability ---
        // OTLP gRPC endpoint (e.g. http://localhost:4317). Empty keeps metrics/traces in-process.
        "OCTOCON_OTLP_ENDPOINT": "",

        // --- Cluster ---
        // Resolution order: FLY_PROCESS_GROUP -> OCTOCON_NODE_GROUP -> "auxiliary".
        // Values: primary | auxiliary | sidecar. Solo dev typically runs as 'primary'.
        "OCTOCON_NODE_GROUP": "primary",

        // --- Sockets ---
        // Outbound WebSocket batch flush threshold in bytes. Empty uses the built-in default.
        "OCTOCON_SOCKET_BATCH_BYTES_THRESHOLD": ""
      },
      "launchUrl": "https://api.octocon.app/swagger/index.html"
    }
  }
}
