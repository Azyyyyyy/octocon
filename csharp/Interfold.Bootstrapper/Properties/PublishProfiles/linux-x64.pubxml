<?xml version="1.0" encoding="utf-8"?>
<!--
  Profile for `dotnet publish /p:PublishProfile=linux-x64`.
  Produces a single self-contained ELF binary at
  bin/Release/net10.0/linux-x64/publish/interfold-bootstrap.

  ReadyToRun is OFF: it cuts cold-start latency by a few hundred ms by precompiling IL to native,
  but inflates the binary by ~70 MiB. The bootstrapper is a one-shot, human-triggered CLI - the
  user is already waiting on docker pulls and TLS-cert generation, so the extra startup time is
  noise. Shipping a smaller binary is the better trade.

  PublishTrimmed is ON with TrimMode=partial: only assemblies that opt in via [assembly:
  AssemblyMetadata("IsTrimmable", "true")] get their unreachable code stripped. The BCL opts in
  (Microsoft.Extensions.*, System.*), but Aspire.Hosting.* and System.CommandLine 3.x preview do
  NOT. Partial trim therefore strips ~5-10 MiB of dead BCL code without touching reflection-
  heavy assemblies. Full trim would slash more but produces hundreds of IL2026/IL2104 warnings
  pointing at Aspire's resource-graph reflection, with non-trivial risk of cutting code only
  reachable via DCP's dynamic resource construction. Validated by re-running the
  StackComesUpHealthy integration test after enabling.

  AOT is off for the same reason - Aspire.Hosting is reflection-heavy and would emit thousands
  of trim/AOT warnings.
-->
<Project>
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>linux-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishTrimmed>true</PublishTrimmed>
    <TrimMode>partial</TrimMode>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <DebugType>embedded</DebugType>
  </PropertyGroup>
</Project>
