<Project Sdk="Microsoft.NET.Sdk">

  <!--
    This project is *not* an Aspire AppHost - it just hosts a CLI that programmatically calls
    InterfoldAppHost.Configure(). Using Aspire.AppHost.Sdk here would override `dotnet publish`
    with Aspire's publisher pipeline (which emits compose/manifest artifacts, not an ELF), so
    we stay on Microsoft.NET.Sdk and reference the AppHost project as a plain library.
  -->

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Interfold.Bootstrapper</RootNamespace>
    <AssemblyName>interfold-bootstrap</AssemblyName>
    <UserSecretsId>c0a8f3d2-1e8c-4d7a-9b9e-2f5d8c4e3a91</UserSecretsId>
    <InvariantGlobalization>true</InvariantGlobalization>
    <!-- LibraryImportAttribute (used for the geteuid P/Invoke in PrerequisitesPhase) requires unsafe blocks. -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!--
      We reference Interfold.AppHost purely as a library (only the static InterfoldAppHost.Configure
      method is invoked). The AppHost's own Main is never called from the bootstrapper, so the
      "self-contained referencing non self-contained executable" guard (NETSDK1150) does not apply.
    -->
    <ValidateExecutableReferencesMatchSelfContained>false</ValidateExecutableReferencesMatchSelfContained>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Reuse the resource graph from Interfold.AppHost via the shared InterfoldAppHost.Configure() entry
      point. The AppHost project is OutputType=Exe, and Aspire.AppHost.Sdk's default behavior for
      project-to-project references between AppHost projects is to omit the reference assembly (they're
      treated as standalone executables). Force inclusion so the bootstrapper can call into the graph
      class directly.
    -->
    <ProjectReference Include="..\Interfold.AppHost\Interfold.AppHost.csproj"
                      ReferenceOutputAssembly="true"
                      IsAspireProjectResource="false"
                      Private="true" />
    <!--
      Shared seed orchestration (SQL/CQL templates + IPostgresExecutor / IScyllaExecutor +
      PostgresSeeder / ScyllaSeeder). Framework-only, no PackageReferences — keeps the
      trimmed binary under the size guardrail. DatabaseInitPhase wires its compose-exec
      adapters into the executors defined there.
    -->
    <ProjectReference Include="..\Interfold.DatabaseBootstrap\Interfold.DatabaseBootstrap.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Aspire Compose publisher (also pulled transitively by Interfold.AppHost; declared explicitly for clarity). -->
    <PackageReference Include="Aspire.Hosting.Docker" Version="13.4.2" />
    <!-- CLI surface: System.CommandLine 2.x beta is the .NET 10 default for command-line apps. -->
    <PackageReference Include="System.CommandLine" Version="3.0.0-preview.5.26302.115" />
    <!--
      Interactive setup surface only. We deliberately do NOT pull in Spectre.Console.Cli — the
      bootstrapper's command/option parsing stays on System.CommandLine (above). Spectre.Console
      is here purely for ConfigPhase.PromptForConfig: TextPrompt / ConfirmationPrompt with inline
      validation, Rule-based section headers, and a Table-driven review-before-commit loop. The
      unit-test project pairs this with Spectre.Console.Testing for the in-memory IAnsiConsole.
    -->
    <PackageReference Include="Spectre.Console" Version="0.55.2" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Expose the bootstrapper's `internal` phase helpers to the unit-test project so it can drive
      validation, secret generation, env post-processing, and other pure-C# logic without round-tripping
      through the public RunAsync entry points. The integration project still does NOT see internals —
      it shells out to the published binary so it tests exactly the same surface a real operator hits.
    -->
    <InternalsVisibleTo Include="Interfold.Bootstrapper.UnitTests" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Support files the AppHost's `WithBindMount` calls resolve against AppContext.BaseDirectory at
      compose-up time. Embedding them keeps the published binary self-sufficient: on first run,
      EmbeddedSupportFiles.EnsureExtracted writes any missing file out next to the binary, and
      leaves operator-edited copies alone. The LogicalName scheme (`support/<relative-on-disk-path>`)
      is the contract the extractor reads — keep new entries under that prefix so they are picked up
      automatically without touching the C# manifest.

      The cassandra-rackdc.*.properties entry is a wildcard so adding a new region is a single-file
      drop into db/scylla/; MSBuild expands %(Filename)%(Extension) per matched file.
    -->
    <EmbeddedResource Include="..\..\db\scylla\cassandra-rackdc.*.properties"
                      LogicalName="support/db/scylla/%(Filename)%(Extension)" />
    <EmbeddedResource Include="..\..\scripts\docker\ensure-host-aio.sh"
                      LogicalName="support/scripts/docker/ensure-host-aio.sh" />
    <EmbeddedResource Include="..\..\web\nginx\default.conf.template"
                      LogicalName="support/web/nginx/default.conf.template" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Cassandra-only deployments build this Dockerfile at compose-up time (see CassandraImagePhase).
      Aspire's compose publisher emits image: "${CASSANDRA_IMAGE}" instead of an inline build:
      section, so the bootstrapper must ship the context next to the binary and docker-build it
      before the stack starts. The FROM cassandra:5 base image publishes arm64 layers, which is
      what makes Raspberry Pi / aarch64 self-hosting viable when Scylla is unavailable.
    -->
    <EmbeddedResource Include="..\..\db\cassandra\Dockerfile"
                      LogicalName="support/db/cassandra/Dockerfile" />
  </ItemGroup>

  <ItemGroup>
    <!--
      systemd unit *templates* consumed by SystemdInstallPhase. We deliberately use a
      "systemd/" prefix rather than the "support/" one above so EmbeddedSupportFiles.EnsureExtracted
      does NOT auto-extract these onto disk on first run. The templates contain
      {{TOKEN}} placeholders that SystemdInstallPhase substitutes before writing to
      /etc/systemd/system/; surfacing the raw, unrendered text next to the binary would
      invite operators to enable a unit that has a literal "{{OUTPUT_DIR}}" in its
      ExecStart=.
    -->
    <EmbeddedResource Include="Phases\SystemdTemplates\interfold.service"
                      LogicalName="systemd/interfold.service" />
    <EmbeddedResource Include="Phases\SystemdTemplates\interfold-backup.service"
                      LogicalName="systemd/interfold-backup.service" />
    <EmbeddedResource Include="Phases\SystemdTemplates\interfold-backup.timer"
                      LogicalName="systemd/interfold-backup.timer" />
  </ItemGroup>

</Project>
