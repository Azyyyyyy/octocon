{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Aspire.Hosting.Dcp": "Warning"
    }
  },
  "Parameters": {
    "include-scylla": true,
    "include-cassandra": false,
    "scylla-topology": "single",
    "include-web": true,
    "postgres-user": "postgres_customuser",
    "scylla-user": "cassandra_customuser"
  },
  "Ports": {
    "postgres": 4200,
    "scylla": 9042,
    "api-http": 5000,
    "api-https": 5001,
    "web-http": 8080,
    "web-https": 8081
  }
}
