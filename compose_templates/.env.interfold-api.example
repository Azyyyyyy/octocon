# Copy this file to compose_templates/.env.interfold-api and fill in secrets.
# Do not commit compose_templates/.env.interfold-api.

# Runtime basics
ASPNETCORE_ENVIRONMENT=Development
OCTOCON_AUTH_EC_PRIVATE_KEY_FILE=/app/octocon-es256-private.pem
OCTOCON_REGION=nam
OCTOCON_NODE_GROUP=primary

# Volume path overrides (optional)
INTERFOLD_APPSETTINGS_SOURCE=./appsettings.json
INTERFOLD_APPSETTINGS_TARGET=/app/appsettings.json
INTERFOLD_CA_PFX_SOURCE=../scripts/Interfold SS Root CA.pfx
INTERFOLD_CA_PFX_TARGET=/app/Interfold SS Root CA.pfx
INTERFOLD_EC_PRIVATE_KEY_SOURCE=/opt/octocon/scripts/ec_private.pem
INTERFOLD_EC_PRIVATE_KEY_TARGET=/app/octocon-es256-private.pem

# Scylla
OCTOCON_SCYLLA_USERNAME=cassandra
OCTOCON_SCYLLA_PASSWORD=cassandra
OCTOCON_SCYLLA_KEYSPACE=nam
OCTOCON_SCYLLA_DATACENTER=nam

# Postgres (container-to-container connection inside Docker network)
OCTOCON_POSTGRES_PORT=5432
OCTOCON_POSTGRES_DB=octocon
OCTOCON_POSTGRES_USER=postgres
OCTOCON_POSTGRES_PASSWORD=change-me

# Persistence mode
OCTOCON_PERSISTENCE=scylla-postgres

# Telemetry
OCTOCON_OTLP_ENDPOINT=

# OAuth/auth challenge
OCTOCON_AUTH_CHALLENGE_ENABLED=true
OCTOCON_AUTH_CHALLENGE_GOOGLE_ENDPOINT=https://accounts.google.com/o/oauth2/v2/auth
OCTOCON_AUTH_CALLBACK_BASE_URL=https://api.octocon.app
OCTOCON_GOOGLE_OAUTH_CLIENT_ID=replace-me
OCTOCON_GOOGLE_OAUTH_CLIENT_SECRET=replace-me
OCTOCON_AUTH_CHALLENGE_GOOGLE_PARAMS=client_id=replace-me,response_type=code,scope=https://www.googleapis.com/auth/userinfo.email

OCTOCON_AUTH_CHALLENGE_DISCORD_ENDPOINT=https://discord.com/api/oauth2/authorize
OCTOCON_DISCORD_OAUTH_CLIENT_ID=replace-me
OCTOCON_DISCORD_OAUTH_CLIENT_SECRET=replace-me
OCTOCON_AUTH_CHALLENGE_DISCORD_PARAMS=response_type=code,scope=identify

# Frontend links
OCTOCON_FRONTEND=http://localhost:8080/
OCTOCON_BETA_FRONTEND=http://localhost:8080/
OCTOCON_DEEPLINK_ADDRESS=https://api.octocon.app/deep

# Required cryptographic secret
ENCRYPTION_PRIVATE_KEY=replace-with-base64-private-key
